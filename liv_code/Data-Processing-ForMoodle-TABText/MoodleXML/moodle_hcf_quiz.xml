<quiz>
  <question type="cloze">
    <name>
      <text>Dynamic HCF Question 01</text>
    </name>
    <questiontext format="html">
      <text><![CDATA[
        <p>Find the Highest Common Factor (HCF) of the following two positive numbers:</p>
        <p style="font-size: 1.2em; font-weight: bold; color: #b45309;">\(112\) and \(40\)</p>
        <p><strong>HCF = </strong> {1:NUMERICAL:=8:0}</p>
      ]]></text>
    </questiontext>
    <generalfeedback format="html">
      <text><![CDATA[<p>The HCF of 112 and 40 is 8.</p>]]></text>
    </generalfeedback>
    <defaultgrade>1.0000000</defaultgrade>
    <penalty>0.3333333</penalty>
    <hidden>0</hidden>
    <idnumber></idnumber>
  </question>
